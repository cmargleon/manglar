---
import { Image } from 'astro:assets';
import Layout from '../layouts/Layout.astro';
import heroVansMujer from '../assets/images/manglar-hero-vans-mujer-marketplace.jpg';
import galleryGorraUnderArmour from '../assets/images/manglar-galeria-gorra-under-armour-hombre.jpeg';
import galleryChamarraLentejuelas from '../assets/images/manglar-galeria-chamarra-lentejuelas-nina.png';
import galleryChamarraDeportiva from '../assets/images/manglar-galeria-chamarra-deportiva-hombre.jpg';
import galleryLookRosa from '../assets/images/manglar-galeria-look-rosa-nina.png';
import productionModaInfantil from '../assets/images/manglar-operacion-catalogo-moda-infantil.png';

const brand = 'Manglar';
const currentYear = new Date().getFullYear();
const whatsappNumber = '525544636484';
const createWhatsAppLink = (message: string) =>
  `https://wa.me/${whatsappNumber}?text=${encodeURIComponent(message)}`;

const whatsappLink = createWhatsAppLink(
  'Hola, quiero impulsar mis ventas en Shein y TikTok Shop con Manglar.'
);
const whatsappDiagnostico = createWhatsAppLink(
  'Hola, quiero solicitar el diagnóstico gratuito de mi tienda en Shein o TikTok Shop.'
);
const whatsappLive = createWhatsAppLink(
  'Hola, me interesa la gestión de TikTok LIVE para mi tienda.'
);
const whatsappCatalogo = createWhatsAppLink(
  'Hola, necesito ayuda con la gestión de catálogo y operación de mi tienda.'
);

const navLinks = [
  { href: '#servicios', label: 'Servicios' },
  { href: '#visuales', label: 'Visuales' },
  { href: '#ia', label: 'Fotos IA' },
  { href: '#tiktok-live', label: 'TikTok LIVE' },
  { href: '#faq', label: 'FAQ' },
  { href: '#contacto', label: 'Contacto' },
];

const liveItems = [
  { icon: 'strategy', title: 'Estrategia previa', desc: 'Definimos qué vender, en qué orden y con qué dinámica de precio para maximizar ventas en cada transmisión.' },
  { icon: 'sell', title: 'Productos y promociones', desc: 'Anclamos los productos, creamos las ofertas de LIVE y activamos descuentos en el momento exacto.' },
  { icon: 'live_tv', title: 'Gestión en transmisión', desc: 'Estructura de venta, timing e interacción con audiencia durante el LIVE para mantener el ritmo de compra.' },
  { icon: 'analytics', title: 'Análisis post-LIVE', desc: 'Revisamos métricas, ventas por producto y comportamiento de audiencia para mejorar cada semana.' },
  { icon: 'loop', title: 'Sistema escalable', desc: 'Documentamos lo que funciona y construimos el playbook para escalar el LIVE con una operación comercial estable.' },
];

const heroPhoto = {
  src: heroVansMujer,
  alt: 'Modelo con gorra floral Vans para catálogo de moda femenina operado por Manglar en Shein y TikTok Shop',
  width: 1050,
  widths: [480, 640, 768, 960, 1050],
  sizes: '(max-width: 768px) calc(100vw - 40px), (max-width: 1200px) 46vw, 620px',
  loading: 'eager' as const,
  priority: true,
};

const galleryWidths = [320, 480, 640, 900];
const gallerySizes = '(max-width: 480px) calc(100vw - 40px), (max-width: 768px) calc(50vw - 28px), 320px';

const photos = [
  {
    src: galleryGorraUnderArmour,
    alt: 'Modelo con gorra negra Under Armour para foto de catálogo de ropa deportiva en marketplace',
    width: 900,
    widths: galleryWidths,
    sizes: gallerySizes,
  },
  {
    src: galleryChamarraLentejuelas,
    alt: 'Niña con chamarra rosa de lentejuelas para imagen de producto infantil en catálogo e-commerce',
    width: 900,
    widths: galleryWidths,
    sizes: gallerySizes,
  },
  {
    src: galleryChamarraDeportiva,
    alt: 'Modelo con chamarra deportiva azul marino para visual de catálogo masculino optimizado para marketplace',
    width: 900,
    widths: galleryWidths,
    sizes: gallerySizes,
  },
  {
    src: galleryLookRosa,
    alt: 'Niña con look rosa y falda rayada para foto de producto infantil optimizada para tienda en línea',
    width: 900,
    widths: galleryWidths,
    sizes: gallerySizes,
  },
];

const carouselPhotos = Array.from({ length: 3 }, (_, loopIndex) =>
  photos.map((photo) => ({
    ...photo,
    isDecorative: loopIndex !== 1,
  }))
).flat();

const productionPhoto = {
  src: productionModaInfantil,
  alt: 'Moda infantil para catálogo e-commerce con dos niñas modelando ropa Barbie sobre fondo rosa para marketplace',
  width: 1536,
  widths: [640, 960, 1200, 1536],
  sizes: '100vw',
};

const serviceCards = [
  {
    icon: 'inventory_2',
    title: 'Gestión integral de catálogo',
    items: [
      'Alta y baja de productos por fases',
      'Títulos, atributos y variantes consistentes',
      'Precios y stock al día',
      'Operación estable de 10 a 5,000+ productos',
    ],
  },
  {
    icon: 'photo_camera',
    title: 'Fotos de producto con IA',
    description:
      'Generamos imágenes limpias, consistentes y pensadas para marketplace sin sesiones eternas, sin fotógrafos y sin semanas de espera.',
    label: 'Más conversión visual',
  },
  {
    icon: 'campaign',
    title: 'Campañas, descuentos y eventos',
    description:
      'Configuramos promociones, cupones y campañas internas para aprovechar cada oportunidad de la plataforma y no dejar ventas sobre la mesa.',
  },
  {
    icon: 'live_tv',
    title: 'Gestión completa de TikTok LIVE',
    description:
      'Estrategia, preparación, productos anclados, promociones, dinámica de venta y optimización posterior para convertir LIVE en una operación comercial estable.',
  },
  {
    icon: 'analytics',
    title: 'Optimización continua',
    description:
      'Revisamos desempeño por SKU, identificamos oportunidades rápidas y ajustamos semana a semana para crecer sin caos operativo.',
  },
];

const visualFeatures = [
  {
    title: 'Imágenes listas para marketplace',
    desc: 'Fotos limpias y consistentes para elevar presentación, clic y conversión sin depender de producción tradicional.',
    icon: 'photo_camera',
  },
  {
    title: 'Alternativas cuando tu contenido no alcanza',
    desc: 'Si ya tienes fotos buenas las aprovechamos; si no, generamos nuevas versiones con IA alineadas a tu catálogo.',
    icon: 'compare',
  },
  {
    title: 'Consistencia visual por colección',
    desc: 'Mantenemos una línea estética clara para que el catálogo se vea ordenado y comercial aunque crezca el número de SKUs.',
    icon: 'palette',
  },
];

const problemItems = [
  { icon: 'category', title: 'Catálogos incompletos', desc: 'Variantes mal cargadas, atributos ausentes y stock desactualizado.' },
  { icon: 'hide_image', title: 'Fotos malas o sin fotos', desc: 'Sin buenas imágenes, la tasa de clics cae antes de que el cliente decida.' },
  { icon: 'event_busy', title: 'Campañas perdidas', desc: 'Fechas clave que pasan sin descuentos ni promociones configuradas.' },
  { icon: 'trending_down', title: 'Ventas que nunca llegaron', desc: 'Operación lenta y desordenada que frena el crecimiento día a día.' },
];

const partnerLogos = [
  {
    label: 'Barbie',
    sector: 'Moda infantil',
    src: '/logos/barbie.svg',
    alt: 'Logo de Barbie',
    width: 1000,
    height: 495,
  },
  {
    label: 'Vans',
    sector: 'Streetwear',
    src: '/logos/vans.svg',
    alt: 'Logo de Vans',
    width: 444,
    height: 197,
  },
  {
    label: 'Under Armour',
    sector: 'Performance',
    src: '/logos/under-armour.svg',
    alt: 'Logo de Under Armour',
    width: 302,
    height: 177,
  },
  {
    label: 'Messi',
    sector: 'Licencias y retail',
    src: '/logos/messi.svg',
    alt: 'Logo de Messi',
    width: 560,
    height: 180,
  },
];
const partnerLogoLoop = Array.from({ length: 3 }, (_, loopIndex) =>
  partnerLogos.map((logo) => ({
    ...logo,
    isDecorative: loopIndex !== 1,
  }))
).flat();

const steps = [
  {
    n: '01',
    title: 'Diagnóstico',
    desc: 'Revisión de cuenta, catálogo, pricing, fotos y oportunidad rápida.',
  },
  {
    n: '02',
    title: 'Ordenar',
    desc: 'Estandarizamos títulos, atributos, variantes y consistencia visual.',
  },
  {
    n: '03',
    title: 'Operar',
    desc: 'Publicación continua, campañas, descuentos y calendario comercial.',
  },
  {
    n: '04',
    title: 'TikTok LIVE',
    desc: 'Preparamos y operamos el LIVE como herramienta real de ventas.',
  },
  {
    n: '05',
    title: 'Optimizar',
    desc: 'Mejoras semanales para convertir mejor y escalar sin carga extra.',
  },
];

const faqItems = [
  {
    question: '¿En cuánto tiempo suben mi catálogo?',
    bullets: [
      'Depende del volumen, pero trabajamos por fases para que empieces a vender rápido.',
      'Primero estructuramos categorías, variantes, precios y stock.',
      'Luego cargamos por bloques manteniendo calidad y orden.',
      'El objetivo no es solo subir, sino optimizar para vender.',
    ],
    note: 'Si tu catálogo ya viene limpio, avanzamos mucho más rápido.',
  },
  {
    question: '¿Puedo usar mis fotos actuales?',
    bullets: [
      'Sí, siempre que cumplan con los estándares del marketplace.',
      'Si necesitan mejora, optimizamos o generamos alternativas con IA.',
      'Buscamos consistencia visual y mayor conversión.',
    ],
    note: 'Si ya tienes buen contenido, lo aprovechamos. Si no, lo elevamos.',
  },
  {
    question: '¿Ustedes manejan campañas y descuentos?',
    bullets: [
      'Sí. Configuramos campañas, descuentos y eventos según el plan acordado.',
      'Activamos promociones estratégicas y optimizamos fechas clave para maximizar ventas.',
    ],
    note: 'La meta es capturar demanda cuando sube y no dejar dinero en la mesa.',
  },
  {
    question: '¿Qué incluye la gestión de TikTok LIVE?',
    bullets: [
      'Definición de estrategia comercial para el LIVE.',
      'Preparación de productos anclados y promociones.',
      'Estructura de venta durante la transmisión.',
      'Análisis y optimización para siguientes lives.',
      'Construcción de una operación escalable y ordenada.',
    ],
  },
  {
    question: '¿Cómo cobran el servicio?',
    bullets: [
      'Trabajamos con un modelo mensual que depende del número de productos.',
      'También influye la frecuencia de actualizaciones y el volumen operativo.',
      'La cantidad de TikTok Lives gestionados puede modificar el alcance.',
      'En algunos casos puede existir componente variable por venta.',
    ],
    note: 'La cotización exacta sale después de revisar tu catálogo y objetivos.',
  },
];

const faqSchemaItems = faqItems.map(({ question, bullets, note }) => ({
  question,
  answer: [...bullets, note].filter(Boolean).join(' '),
}));

const contactChannels = [
  {
    href: whatsappDiagnostico,
    icon: 'search',
    title: 'Diagnóstico gratuito',
    desc: 'No sé por dónde empezar, quiero que revisen mi tienda',
  },
  {
    href: whatsappCatalogo,
    icon: 'inventory_2',
    title: 'Operar mi catálogo',
    desc: 'Necesito gestión de productos, fotos y campañas',
  },
  {
    href: whatsappLive,
    icon: 'live_tv',
    title: 'TikTok LIVE',
    desc: 'Quiero arrancar o mejorar mis transmisiones',
  },
];

const footerServiceLinks = [
  'Gestión integral de tienda',
  'Fotos de producto con IA',
  'Campañas y descuentos',
  'TikTok LIVE',
];
const footerProcessLinks = ['Diagnóstico', 'Ordenar catálogo', 'Operar', 'Optimizar'];
---

<Layout
  title="Manglar | Agencia para Shein, TikTok Shop y TikTok LIVE en México"
  description="Manglar opera Shein y TikTok Shop de principio a fin en México: catálogo, fotos de producto con IA, campañas, descuentos y TikTok LIVE para vender más sin frenar tu operación."
  faqItems={faqSchemaItems}
>
  <nav class="site-nav--glass site-nav">
    <div class="site-nav__inner">
      <a href="/" class="font-headline site-nav__brand site-nav__brand-link fs-brand" aria-label="Ir al inicio de Manglar">{brand}</a>
      <div class="site-nav__links">
        {navLinks.map((link) => (
          <a href={link.href} class="site-nav__link fs-nav">{link.label}</a>
        ))}
      </div>
      <button
        class="site-nav__menu-button"
        type="button"
        aria-label="Abrir menú"
        aria-expanded="false"
        aria-controls="mobile-nav"
        data-menu-button
      >
        <span class="material-symbols-outlined site-nav__menu-icon" data-menu-icon>menu</span>
      </button>
      <a
        href={whatsappLink}
        target="_blank"
        rel="noopener noreferrer"
        class="site-nav__cta whatsapp-link"
      >
        WhatsApp
      </a>
    </div>
  </nav>

  <div id="mobile-nav" class="mobile-nav" role="dialog" aria-label="Menú de navegación" hidden data-mobile-nav>
    {navLinks.map((link) => (
      <a href={link.href} class="mobile-nav__link">{link.label}</a>
    ))}
  </div>

  <main class="site-main">
    <section class="hero">
      <div class="hero__content">
        <div class="hero__eyebrow">
          <span class="hero__eyebrow-dot"></span>
          <span class="hero__eyebrow-copy fs-kicker">Operación completa + TikTok LIVE + IA</span>
        </div>

        <h1 class="font-headline hero__heading hero__title fs-hero-title">
          Impulsa tus ventas<br />
          en <span class="brand-accent">Shein</span> y<br />
          TikTok Shop.
        </h1>

        <p class="hero__copy fs-body-lg">
          Nos encargamos de tu catálogo, fotos con IA, campañas, descuentos y TikTok LIVE para que tu tienda venda más sin que tú tengas que operar todo el día.
        </p>

        <div class="hero__actions">
          <a
            href={whatsappLink}
            target="_blank"
            rel="noopener noreferrer"
            class="whatsapp-link hero__primary-link fs-body"
          >
            Escríbenos por WhatsApp
          </a>
          <a href="#servicios" class="hero__secondary-link fs-body">Ver servicios</a>
        </div>
      </div>

      <div class="hero__media">
        <Image
          src={heroPhoto.src}
          alt={heroPhoto.alt}
          width={heroPhoto.width}
          format="webp"
          quality="mid"
          widths={heroPhoto.widths}
          sizes={heroPhoto.sizes}
          loading={heroPhoto.loading}
          priority={heroPhoto.priority}
          class="hero__image"
        />
        <div class="hero__media-overlay"></div>
      </div>
    </section>

    <section id="servicios" class="services section-gutter page-container">
      <div class="services__intro">
        <h2 class="font-headline fs-section-title tracking-tight lh-heading">
          Operamos tu tienda.<br />
          <em class="text-accent">Tú ves resultados.</em>
        </h2>
        <div class="section-divider"></div>
      </div>

      <div class="services__grid">
        <div class="service-card service-card--catalog">
          <span class="material-symbols-outlined service-card__icon--lg">{serviceCards[0].icon}</span>
          <h3 class="font-headline service-card__title service-card__title--xl fs-card-title-xl">
            {serviceCards[0].title}
          </h3>
          <ul class="service-card__list">
            {serviceCards[0].items.map((item) => (
              <li class="service-card__list-item fs-body">
                <span class="material-symbols-outlined service-card__check">check_circle</span>
                {item}
              </li>
            ))}
          </ul>
          <div class="service-card__bg-icon-wrap">
            <span class="material-symbols-outlined service-card__bg-icon">inventory_2</span>
          </div>
        </div>

        <div class="service-card service-card--live">
          <div>
            <div class="service-card__icon-badge">
              <span class="material-symbols-outlined service-card__icon-symbol">{serviceCards[3].icon}</span>
            </div>
            <h3 class="font-headline service-card__title fs-card-title-lg">{serviceCards[3].title}</h3>
            <p class="service-card__copy service-card__copy--live fs-body">{serviceCards[3].description}</p>
          </div>
        </div>

        {serviceCards.slice(1, 3).map((service) => (
          <div class="service-card">
            <span class="material-symbols-outlined service-card__icon--md">
              {service.icon}
            </span>
            <h3 class="font-headline service-card__title fs-card-title-sm">{service.title}</h3>
            <p class="service-card__copy fs-body">{service.description}</p>
          </div>
        ))}

        <div class="service-card">
          <span class="material-symbols-outlined service-card__icon--md">{serviceCards[4].icon}</span>
          <h3 class="font-headline service-card__title fs-card-title-sm">{serviceCards[4].title}</h3>
          <p class="service-card__copy fs-body">{serviceCards[4].description}</p>
        </div>
      </div>
    </section>

    <section class="challenge">
      <Image
        src={productionPhoto.src}
        alt={productionPhoto.alt}
        width={productionPhoto.width}
        format="webp"
        quality="mid"
        widths={productionPhoto.widths}
        sizes={productionPhoto.sizes}
        loading="lazy"
        class="challenge__image"
      />
      <div class="challenge__overlay"></div>
      <div class="challenge__content">
        <h2 class="font-headline challenge__title fs-section-title-compact">
          El tiempo operativo está<br />
          <em class="text-accent">frenando tu crecimiento.</em>
        </h2>
        <p class="challenge__copy fs-body-lg">
          Subir productos, crear fotos, gestionar precios, campañas, descuentos y contenido comercial requiere horas. Manglar toma esa carga y la convierte en una operación continua para Shein y TikTok Shop.
        </p>
        <div class="challenge__list">
          {problemItems.map(({ icon, title, desc }) => (
            <div class="challenge-card">
              <div class="challenge-card__header">
                <span class="material-symbols-outlined challenge-card__icon">{icon}</span>
                <span class="challenge-card__title fs-body">{title}</span>
              </div>
              <p class="challenge-card__copy fs-body">{desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section id="visuales" class="visual-gallery">
      <div class="page-container">
        <div class="visual-gallery__header">
          <div>
            <h2 class="font-headline fs-section-title-wide tracking-tight lh-snug">
              Visuales que<br />
              <em class="text-accent text-accent--gallery">sí convierten</em>
            </h2>
            <p class="visual-gallery__quote fs-body-lg">
              <strong>"Imágenes limpias, consistentes y optimizadas para marketplace. Sin sesiones, sin fotógrafos y sin semanas de espera."</strong>
            </p>
          </div>
        </div>

        <div class="visual-gallery__carousel">
          <div class="visual-gallery__track" data-gallery-track aria-label="Carrusel de fotos de producto">
            {carouselPhotos.map((photo) => (
              <div class="visual-gallery__card" aria-hidden={photo.isDecorative ? 'true' : 'false'}>
                <Image
                  src={photo.src}
                  alt={photo.isDecorative ? '' : photo.alt}
                  width={photo.width}
                  format="webp"
                  quality="mid"
                  widths={photo.widths}
                  sizes={photo.sizes}
                  loading="lazy"
                  class="visual-gallery__image"
                />
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>

    <section id="ia" class="ai-photos section-gutter">
      <div class="page-container">
        <div class="ai-photos__grid">
          <div class="ai-photos__copy">
            <h2 class="font-headline fs-section-title tracking-tight ai-photos__title">
              Fotos de producto con<br /><em class="text-accent">Inteligencia Artificial</em>
            </h2>
            <p class="ai-photos__text fs-body-lg">
              Las fotos son uno de los cuellos de botella más pesados en e-commerce. Generamos imágenes limpias, consistentes y optimizadas para marketplace sin sesiones largas, sin fotógrafos y sin costos variables para que tu catálogo se vea vendible desde el primer scroll.
            </p>
          </div>

          <div class="ai-photos__features">
            {visualFeatures.map((item) => (
              <div class="ai-feature-card">
                <div class="ai-feature-card__icon-wrap">
                  <span class="material-symbols-outlined ai-feature-card__icon">{item.icon}</span>
                </div>
                <div>
                  <h3 class="font-headline ai-feature-card__title fs-body">{item.title}</h3>
                  <p class="ai-feature-card__copy fs-body">{item.desc}</p>
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>

    {/* Activar esta sección cuando haya más clientes/logos para reforzar prueba social. */}
    {/*
    <section id="marcas" class="brand-strip">
      <div class="page-container">
        <h2 class="font-headline brand-strip__title fs-section-title">
          Empresas que nos eligieron
        </h2>
        <div class="brand-strip__carousel" aria-label="Carrusel de logos de empresas que eligieron Manglar">
          <div class="brand-strip__track">
            {partnerLogoLoop.map((logo) => (
              <div class="brand-strip__item" aria-hidden={logo.isDecorative ? 'true' : 'false'}>
                <img
                  src={logo.src}
                  alt={logo.isDecorative ? '' : logo.alt}
                  width={logo.width}
                  height={logo.height}
                  loading="lazy"
                  decoding="async"
                  class="brand-strip__logo"
                />
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>
    */}

    <section id="proceso" class="process">
      <div class="process__inner">
        <div class="process__header">
          <div>
            <div class="process__eyebrow fs-label">Proceso</div>
            <h2 class="font-headline fs-section-title tracking-tight lh-snug">
              Cómo ordenamos,<br />
              operamos y escalamos<br />
              tu tienda
            </h2>
          </div>
          <p class="process__intro fs-body-lg">
            Empezamos con diagnóstico, ordenamos catálogo, activamos campañas y llevamos TikTok LIVE a un flujo comercial repetible. El objetivo es vender más con una operación estable y medible.
          </p>
        </div>

        <div class="process__grid">
          <div class="process__line" aria-hidden="true"></div>
          {steps.map((step) => (
            <article class="process-step">
              <div class="process-step__number fs-label">{step.n}</div>
              <h3 class="font-headline process-step__title fs-card-title-sm">{step.title}</h3>
              <p class="process-step__copy fs-body">{step.desc}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section id="tiktok-live" class="live-sales">
      <div class="page-container">
        <div class="live-sales__intro">
          <div class="live-sales__intro-copy">
            <h2 class="font-headline live-sales__title fs-section-title">
              TikTok LIVE que<br />
              <em class="text-accent">vende de verdad</em>
            </h2>
            <p class="live-sales__copy fs-body-lg">
              No es solo transmitir. Un LIVE bien operado es la herramienta de mayor conversión en TikTok Shop cuando tiene estrategia, productos correctos y gestión activa en tiempo real.
            </p>
            <a
              href={whatsappLive}
              target="_blank"
