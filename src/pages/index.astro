        <div style="display:flex;gap:20px;">
          <a href="#visuales" style="color:rgba(255,255,255,0.38);text-decoration:none;"><span class="material-symbols-outlined" style="font-size:1.2rem;">image</span></a>
          <a href="#faq" style="color:rgba(255,255,255,0.38);text-decoration:none;"><span class="material-symbols-outlined" style="font-size:1.2rem;">help</span></a>
