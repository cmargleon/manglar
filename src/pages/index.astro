---
import { Image } from 'astro:assets';
import Layout from '../layouts/Layout.astro';
import heroVansMujer from '../assets/images/manglar-hero-vans-mujer-marketplace.jpg';
import galleryGorraUnderArmour from '../assets/images/manglar-galeria-gorra-under-armour-hombre.jpeg';
import galleryChamarraLentejuelas from '../assets/images/manglar-galeria-chamarra-lentejuelas-nina.png';
import galleryChamarraDeportiva from '../assets/images/manglar-galeria-chamarra-deportiva-hombre.jpg';
import galleryLookRosa from '../assets/images/manglar-galeria-look-rosa-nina.png';
import productionModaInfantil from '../assets/images/manglar-operacion-catalogo-moda-infantil.png';

const brand = 'Manglar';
const whatsappNumber = '525544636484';
const whatsappText = encodeURIComponent(
  'Hola, quiero impulsar mis ventas en Shein y TikTok Shop con Manglar.'
);
const whatsappLink = `https://wa.me/${whatsappNumber}?text=${whatsappText}`;

const whatsappDiagnostico = `https://wa.me/${whatsappNumber}?text=${encodeURIComponent('Hola, quiero solicitar el diagnóstico gratuito de mi tienda en Shein o TikTok Shop.')}`;
const whatsappLive = `https://wa.me/${whatsappNumber}?text=${encodeURIComponent('Hola, me interesa la gestión de TikTok LIVE para mi tienda.')}`;
const whatsappCatalogo = `https://wa.me/${whatsappNumber}?text=${encodeURIComponent('Hola, necesito ayuda con la gestión de catálogo y operación de mi tienda.')}`;

const liveItems = [
  { icon: 'strategy', title: 'Estrategia previa', desc: 'Definimos qué vender, en qué orden y con qué dinámica de precio para maximizar ventas en cada transmisión.' },
  { icon: 'sell', title: 'Productos y promociones', desc: 'Anclamos los productos, creamos las ofertas de LIVE y activamos descuentos en el momento exacto.' },
  { icon: 'live_tv', title: 'Gestión en transmisión', desc: 'Estructura de venta, timing e interacción con audiencia durante el LIVE para mantener el ritmo de compra.' },
  { icon: 'analytics', title: 'Análisis post-LIVE', desc: 'Revisamos métricas, ventas por producto y comportamiento de audiencia para mejorar cada semana.' },
  { icon: 'loop', title: 'Canal repetible', desc: 'Documentamos lo que funciona y construimos el playbook para escalar el LIVE como canal de venta estable.' },
];

const heroPhoto = {
  src: heroVansMujer,
  alt: 'Modelo con gorra floral Vans y outfit casual para catálogo femenino de moda en marketplace',
  width: 1050,
  loading: 'eager' as const,
  priority: true,
};
const photos = [
  {
    src: galleryGorraUnderArmour,
    alt: 'Modelo con gorra negra Under Armour para foto de catálogo de ropa deportiva en marketplace',
    width: 900,
  },
  {
    src: galleryChamarraLentejuelas,
    alt: 'Niña con chamarra rosa de lentejuelas para imagen de producto infantil en catálogo e-commerce',
    width: 900,
  },
  {
    src: galleryChamarraDeportiva,
    alt: 'Modelo con chamarra deportiva azul marino para visual de catálogo masculino optimizado para marketplace',
    width: 900,
  },
  {
    src: galleryLookRosa,
    alt: 'Niña con look rosa y falda rayada para foto de producto infantil optimizada para tienda en línea',
    width: 900,
  },
];
const productionPhoto = {
  src: productionModaInfantil,
  alt: 'Moda infantil para catálogo e-commerce con dos niñas modelando ropa Barbie sobre fondo rosa',
  width: 1536,
};

const serviceCards = [
  {
    icon: 'inventory_2',
    title: 'Gestión integral de catálogo',
    description:
      'Subimos, bajamos, ordenamos y optimizamos productos, variantes, categorías, precios y stock para que tu tienda siempre esté lista para vender.',
    items: [
      'Alta y baja de productos por fases',
      'Títulos, atributos y variantes consistentes',
      'Precios y stock al día',
      'Operación estable de 10 a 5,000+ productos',
    ],
  },
  {
    icon: 'photo_camera',
    title: 'Fotos de producto con IA',
    description:
      'Generamos imágenes limpias, consistentes y pensadas para marketplace sin sesiones eternas, sin fotógrafos y sin semanas de espera.',
    label: 'Más conversión visual',
  },
  {
    icon: 'campaign',
    title: 'Campañas, descuentos y eventos',
    description:
      'Configuramos promociones, cupones y campañas internas para aprovechar cada oportunidad de la plataforma y no dejar ventas sobre la mesa.',
  },
  {
    icon: 'live_tv',
    title: 'Gestión completa de TikTok LIVE',
    description:
      'Estrategia, preparación, productos anclados, promociones, dinámica de venta y optimización posterior para convertir LIVE en un canal repetible.',
  },
  {
    icon: 'analytics',
    title: 'Optimización continua',
    description:
      'Revisamos desempeño por SKU, identificamos oportunidades rápidas y ajustamos semana a semana para crecer sin caos operativo.',
  },
];

const visualFeatures = [
  {
    title: 'Imágenes listas para marketplace',
    desc: 'Fotos limpias y consistentes para elevar presentación, clic y conversión sin depender de producción tradicional.',
    icon: 'photo_camera',
  },
  {
    title: 'Alternativas cuando tu contenido no alcanza',
    desc: 'Si ya tienes fotos buenas las aprovechamos; si no, generamos nuevas versiones con IA alineadas a tu catálogo.',
    icon: 'compare',
  },
  {
    title: 'Consistencia visual por colección',
    desc: 'Mantenemos una línea estética clara para que el catálogo se vea ordenado y comercial aunque crezca el número de SKUs.',
    icon: 'palette',
  },
];

const steps = [
  {
    n: '01',
    title: 'Diagnóstico',
    desc: 'Revisión de cuenta, catálogo, pricing, fotos y oportunidad rápida.',
  },
  {
    n: '02',
    title: 'Ordenar',
    desc: 'Estandarizamos títulos, atributos, variantes y consistencia visual.',
  },
  {
    n: '03',
    title: 'Operar',
    desc: 'Publicación continua, campañas, descuentos y calendario comercial.',
  },
  {
    n: '04',
    title: 'TikTok LIVE',
    desc: 'Preparamos y operamos el LIVE como herramienta real de ventas.',
  },
  {
    n: '05',
    title: 'Optimizar',
    desc: 'Mejoras semanales para convertir mejor y escalar sin carga extra.',
  },
];

const faqItems = [
  {
    question: '¿En cuánto tiempo suben mi catálogo?',
    bullets: [
      'Depende del volumen, pero trabajamos por fases para que empieces a vender rápido.',
      'Primero estructuramos categorías, variantes, precios y stock.',
      'Luego cargamos por bloques manteniendo calidad y orden.',
      'El objetivo no es solo subir, sino optimizar para vender.',
    ],
    note: 'Si tu catálogo ya viene limpio, avanzamos mucho más rápido.',
  },
  {
    question: '¿Puedo usar mis fotos actuales?',
    bullets: [
      'Sí, siempre que cumplan con los estándares del marketplace.',
      'Si necesitan mejora, optimizamos o generamos alternativas con IA.',
      'Buscamos consistencia visual y mayor conversión.',
    ],
    note: 'Si ya tienes buen contenido, lo aprovechamos. Si no, lo elevamos.',
  },
  {
    question: '¿Ustedes manejan campañas y descuentos?',
    bullets: [
      'Sí. Configuramos campañas, descuentos y eventos según el plan acordado.',
      'Activamos promociones estratégicas y optimizamos fechas clave para maximizar ventas.',
    ],
    note: 'La meta es capturar demanda cuando sube y no dejar dinero en la mesa.',
  },
  {
    question: '¿Qué incluye la gestión de TikTok LIVE?',
    bullets: [
      'Definición de estrategia comercial para el LIVE.',
      'Preparación de productos anclados y promociones.',
      'Estructura de venta durante la transmisión.',
      'Análisis y optimización para siguientes lives.',
      'Construcción de un canal repetible y escalable.',
    ],
  },
  {
    question: '¿Cómo cobran el servicio?',
    bullets: [
      'Trabajamos con un modelo mensual que depende del número de productos.',
      'También influye la frecuencia de actualizaciones y el volumen operativo.',
      'La cantidad de TikTok Lives gestionados puede modificar el alcance.',
      'En algunos casos puede existir componente variable por venta.',
    ],
    note: 'La cotización exacta sale después de revisar tu catálogo y objetivos.',
  },
];
---

<Layout
  title="Manglar | Gestión Shein, TikTok Shop, fotos de producto y TikTok LIVE"
  description="Manglar opera Shein y TikTok Shop de principio a fin en México: catálogo, fotos de producto con IA, campañas, descuentos y TikTok LIVE para vender más sin dedicarle horas a la operación."
>
  <style>
    :root {
      --nav-height: 91px;
    }

    #servicios,
    #visuales,
    #ia,
    #proceso,
    #faq,
    #contacto {
      scroll-margin-top: 112px;
    }

    main {
      padding-top: var(--nav-height);
    }

    @media (max-width: 768px) {
      :root {
        --nav-height: 79px;
      }

      .nav-inner { padding: 18px 20px !important; }
      .nav-links { display: none !important; }
      .nav-cta { padding: 10px 18px !important; font-size: 0.72rem !important; }

      .hero-grid { grid-template-columns: 1fr !important; height: auto !important; min-height: 100svh !important; }
      .hero-text { padding: 40px 24px 60px !important; }
      .hero-photo { display: block !important; height: 260px !important; order: -1; }
      .hero-h1 { font-size: clamp(3rem, 12vw, 5rem) !important; }

      .section-pad { padding-left: 20px !important; padding-right: 20px !important; }

      .services-section { padding: 80px 20px !important; }
      .services-grid { grid-template-columns: 1fr !important; }
      .catalog-card { grid-column: span 1 !important; }

      .fullwidth-section { height: 520px !important; }
      .fullwidth-text { padding: 40px 20px !important; }
      .problem-pills { grid-template-columns: 1fr !important; }

      .gallery-section { padding: 80px 20px !important; }
      .gallery-header { flex-direction: column !important; align-items: flex-start !important; gap: 24px !important; }
      .gallery-grid { grid-template-columns: repeat(2, 1fr) !important; }
      .gallery-stagger { margin-top: 0 !important; }

      .ia-section { padding: 80px 20px !important; }
      .ia-grid { grid-template-columns: 1fr !important; gap: 48px !important; }

      .steps-section { padding: 0 20px 80px !important; }
      .steps-inner { padding-top: 80px !important; }
      .steps-grid { grid-template-columns: 1fr 1fr !important; gap: 28px !important; }
      .steps-line { display: none !important; }

      .faq-section { padding: 80px 20px !important; }
      .faq-grid { grid-template-columns: 1fr !important; }

      .cta-section { padding: 80px 20px !important; }

      .footer-inner { padding: 56px 20px !important; }
      .footer-grid { grid-template-columns: 1fr 1fr !important; gap: 40px !important; }
      .footer-brand { grid-column: span 2 !important; }
      .footer-bottom-inner { flex-direction: column !important; gap: 16px !important; text-align: center !important; }
      .footer-bottom { padding: 0 20px 32px !important; }

      .floating-whatsapp { bottom: 20px !important; right: 20px !important; left: auto !important; width: 58px !important; height: 58px !important; }
    }

    @media (max-width: 480px) {
      .steps-grid { grid-template-columns: 1fr !important; }
      .gallery-grid { grid-template-columns: 1fr !important; }
      .footer-grid { grid-template-columns: 1fr !important; }
      .footer-brand { grid-column: span 1 !important; }
    }

    .faq-item {
      background: #161616;
      border: 1px solid rgba(255, 255, 255, 0.06);
      border-radius: 1.25rem;
      overflow: hidden;
    }

    .faq-item summary {
      list-style: none;
      cursor: pointer;
      padding: 24px 28px;
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 20px;
    }

    .faq-item summary::-webkit-details-marker {
      display: none;
    }

    .faq-icon {
      transition: transform 0.2s ease;
    }

    .faq-item[open] .faq-icon {
      transform: rotate(45deg);
    }

    /* ─── Nav links hover ─── */
    .nav-links a {
      transition: color 0.2s ease;
    }
    .nav-links a:hover { color: #fff; }

    /* ─── Service card hover ─── */
    .service-card {
      transition: transform 0.25s ease, border-color 0.25s ease, box-shadow 0.25s ease;
    }
    .service-card:hover {
      transform: translateY(-4px);
      border-color: rgba(255,140,149,0.28) !important;
      box-shadow: 0 12px 40px rgba(0,0,0,0.35);
    }

    /* ─── Hero image ─── */
    .hero-img {
      width: 100%; height: 100%;
      object-fit: cover; object-position: center top;
      filter: grayscale(100%);
      transition: filter 0.8s ease;
    }
    .hero-img:hover { filter: grayscale(0%); }

    /* ─── Gallery image ─── */
    .gallery-img {
      width: 100%; height: 100%;
      object-fit: cover;
      filter: grayscale(80%);
      transition: filter 0.5s ease, transform 0.5s ease;
    }
    .gallery-img:hover {
      filter: grayscale(0%);
      transform: scale(1.04);
    }

    /* ─── WhatsApp CTA buttons ─── */
    .btn-whatsapp {
      transition: transform 0.2s ease;
    }
    .btn-whatsapp:hover { transform: scale(1.03); }

    /* ─── Floating WhatsApp ─── */
    .floating-whatsapp {
      transition: transform 0.2s ease, box-shadow 0.2s ease !important;
    }
    .floating-whatsapp:hover {
      transform: scale(1.12) !important;
      box-shadow: 0 8px 36px rgba(37,211,102,0.55) !important;
    }

    /* ─── FAQ smooth expand ─── */
    .faq-body {
      display: grid;
      grid-template-rows: 0fr;
      transition: grid-template-rows 0.28s ease;
    }
    .faq-item[open] .faq-body { grid-template-rows: 1fr; }
    .faq-body-inner { overflow: hidden; }

    /* ─── Reduced motion ─── */
    @media (prefers-reduced-motion: reduce) {
      .hero-img, .gallery-img, .service-card, .btn-whatsapp,
      .floating-whatsapp, .faq-body { transition: none !important; }
    }

    /* ─── Mobile nav menu ─── */
    #menu-btn { display: none; }
    #mobile-menu { display: none; }
    .mobile-nav-link {
      display: block;
      padding: 14px 16px;
      border-radius: 0.75rem;
      font-size: 0.975rem;
      font-weight: 600;
      color: rgba(255,255,255,0.8);
      text-decoration: none;
      transition: background 0.15s ease, color 0.15s ease;
    }
    .mobile-nav-link:hover { background: rgba(255,255,255,0.06); color: #fff; }

    /* ─── Footer social icons ─── */
    .social-icon {
      display: flex;
      align-items: center;
      justify-content: center;
      width: 38px;
      height: 38px;
      border-radius: 10px;
      background: rgba(255,255,255,0.06);
      border: 1px solid rgba(255,255,255,0.08);
      color: rgba(255,255,255,0.6);
      text-decoration: none;
      transition: background 0.2s ease, color 0.2s ease;
    }
    .social-icon:hover { background: rgba(255,255,255,0.12); color: #fff; }

    /* ─── Mobile hero photo ─── */
    @media (max-width: 768px) {
      .hero-photo { display: block !important; height: 260px !important; order: -1; }
      .hero-text { padding: 40px 24px 60px !important; }
      #menu-btn { display: flex !important; }
      .hero-img { filter: grayscale(0%) !important; }
    }

    /* ─── TikTok LIVE section ─── */
    .live-intro-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 80px;
      align-items: start;
      margin-bottom: 80px;
    }
    .live-compare-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 20px;
    }
    .live-features-grid {
      display: grid;
      grid-template-columns: repeat(5, 1fr);
      gap: 20px;
    }

    /* ─── Email capture ─── */
    .email-capture-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 80px;
      align-items: center;
    }
    .form-input {
      width: 100%;
      background: rgba(255,255,255,0.06);
      border: 1px solid rgba(255,255,255,0.1);
      border-radius: 0.875rem;
      padding: 16px 20px;
      color: #fff;
      font-size: 0.95rem;
      font-family: 'Manrope', sans-serif;
      outline: none;
      box-sizing: border-box;
      transition: border-color 0.2s ease;
    }
    .form-input:focus { border-color: rgba(255,140,149,0.5); }
    .form-input::placeholder { color: rgba(255,255,255,0.36); }

    /* ─── CTA channels ─── */
    .cta-channels {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 16px;
      max-width: 900px;
      margin: 0 auto 40px;
    }
    .cta-channel-card:hover { background: rgba(255,255,255,0.22) !important; }

    /* ─── Pulse animation ─── */
    @keyframes pulse {
      0%, 100% { opacity: 1; transform: scale(1); }
      50% { opacity: 0.6; transform: scale(0.85); }
    }

    @media (max-width: 768px) {
      .live-intro-grid { grid-template-columns: 1fr !important; gap: 48px !important; }
      .live-compare-grid { grid-template-columns: 1fr !important; }
      .live-features-grid { grid-template-columns: 1fr 1fr !important; gap: 16px !important; }
      .email-capture-grid { grid-template-columns: 1fr !important; gap: 48px !important; }
      .cta-channels { grid-template-columns: 1fr !important; max-width: 100% !important; }
    }
    @media (max-width: 480px) {
      .live-features-grid { grid-template-columns: 1fr !important; }
    }
  </style>

  <nav class="glass-nav" style="position:fixed;top:0;width:100%;z-index:50;">
    <div class="nav-inner" style="max-width:1400px;margin:0 auto;padding:22px 40px;display:flex;justify-content:space-between;align-items:center;">
      <div class="font-headline" style="font-weight:900;font-size:1.6rem;letter-spacing:-0.04em;color:#fff;">{brand}</div>
      <div class="nav-links" style="display:flex;gap:40px;">
        <a href="#servicios" style="font-size:0.875rem;font-weight:500;color:rgba(255,255,255,0.7);text-decoration:none;">Servicios</a>
        <a href="#visuales" style="font-size:0.875rem;font-weight:500;color:rgba(255,255,255,0.7);text-decoration:none;">Visuales</a>
        <a href="#ia" style="font-size:0.875rem;font-weight:500;color:rgba(255,255,255,0.7);text-decoration:none;">Fotos IA</a>
        <a href="#tiktok-live" style="font-size:0.875rem;font-weight:500;color:rgba(255,255,255,0.7);text-decoration:none;">TikTok LIVE</a>
        <a href="#proceso" style="font-size:0.875rem;font-weight:500;color:rgba(255,255,255,0.7);text-decoration:none;">Cómo funciona</a>
        <a href="#faq" style="font-size:0.875rem;font-weight:500;color:rgba(255,255,255,0.7);text-decoration:none;">FAQ</a>
        <a href="#contacto" style="font-size:0.875rem;font-weight:500;color:rgba(255,255,255,0.7);text-decoration:none;">Contacto</a>
      </div>
      <button id="menu-btn" aria-label="Abrir menú" aria-expanded="false" style="background:none;border:none;cursor:pointer;padding:8px;color:#fff;align-items:center;justify-content:center;">
        <span id="menu-icon" class="material-symbols-outlined" style="font-size:1.5rem;">menu</span>
      </button>
      <a
        href={whatsappLink}
        target="_blank"
        rel="noopener noreferrer"
        class="nav-cta btn-whatsapp"
        style="background:linear-gradient(135deg,#25D366,#128C7E);color:#fff;padding:13px 30px;border-radius:9999px;font-size:0.78rem;font-weight:700;letter-spacing:0.06em;text-transform:uppercase;text-decoration:none;font-family:'Plus Jakarta Sans',sans-serif;"
      >
        WhatsApp
      </a>
    </div>
  </nav>

  <div id="mobile-menu" role="dialog" aria-label="Menú de navegación" style="position:fixed;top:var(--nav-height);left:0;right:0;z-index:49;background:rgba(14,14,14,0.98);backdrop-filter:blur(20px);border-bottom:1px solid rgba(255,255,255,0.08);padding:16px 20px 24px;flex-direction:column;gap:4px;">
    <a href="#servicios" class="mobile-nav-link">Servicios</a>
    <a href="#visuales" class="mobile-nav-link">Visuales</a>
    <a href="#ia" class="mobile-nav-link">Fotos IA</a>
    <a href="#tiktok-live" class="mobile-nav-link">TikTok LIVE</a>
    <a href="#proceso" class="mobile-nav-link">Cómo funciona</a>
    <a href="#faq" class="mobile-nav-link">FAQ</a>
    <a href="#contacto" class="mobile-nav-link">Contacto</a>
  </div>

  <main>
    <section class="hero-grid" style="min-height:calc(100vh - var(--nav-height));display:grid;grid-template-columns:1fr 1fr;overflow:visible;">
      <div class="hero-text" style="display:flex;flex-direction:column;justify-content:center;padding:64px 48px 64px 40px;background:#0e0e0e;position:relative;">
        <div style="display:inline-flex;align-items:center;gap:8px;background:linear-gradient(135deg,#ff8c95,#e80048);padding:7px 16px;border-radius:9999px;margin-bottom:28px;width:fit-content;">
          <span style="width:6px;height:6px;background:#fff;border-radius:50%;display:inline-block;"></span>
          <span style="font-size:0.65rem;font-weight:700;letter-spacing:0.1em;text-transform:uppercase;color:#fff;">Operación completa + TikTok LIVE + IA</span>
        </div>

        <h1 class="font-headline hero-h1" style="font-size:clamp(3.35rem,6vw,6.2rem);font-weight:900;line-height:0.92;letter-spacing:-0.04em;margin-bottom:24px;max-width:760px;">
          Impulsa tus ventas<br />
          en <span style="color:#ff8c95;">Shein</span> y<br />
          TikTok Shop.
        </h1>

        <p style="font-size:1.1rem;line-height:1.7;color:rgba(255,255,255,0.7);max-width:530px;margin-bottom:18px;">
          Nos encargamos de tu catálogo, fotos con IA, campañas, descuentos y TikTok LIVE para que tu tienda venda más sin que tú tengas que operar todo el día.
        </p>

        <p style="font-size:0.95rem;line-height:1.7;color:rgba(255,255,255,0.52);max-width:540px;margin-bottom:32px;">
          Operación estable para tiendas de 10 a 5,000+ productos, con foco en orden, velocidad y optimización continua.
        </p>

        <div style="display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:12px;max-width:620px;margin-bottom:32px;">
          {[
            { icon: 'store', text: 'Gestión integral de tienda y productos.' },
            { icon: 'auto_awesome', text: 'Imágenes con IA diseñadas para conversión.' },
            { icon: 'campaign', text: 'Campañas, descuentos y eventos activos.' },
            { icon: 'live_tv', text: 'Ejecución completa de TikTok LIVE.' },
          ].map(({ icon, text }) => (
