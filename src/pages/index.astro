<script>
  const btn = document.querySelector('[data-menu-button]') as HTMLButtonElement | null;
  const menu = document.querySelector('[data-mobile-nav]') as HTMLDivElement | null;
  const icon = document.querySelector('[data-menu-icon]') as HTMLSpanElement | null;

  const setMobileNavState = (isOpen: boolean) => {
    if (!btn || !menu || !icon) return;

    menu.hidden = !isOpen;
    menu.classList.toggle('is-open', isOpen);
    icon.textContent = isOpen ? 'close' : 'menu';
    btn.setAttribute('aria-expanded', String(isOpen));
  };

  btn?.addEventListener('click', () => {
    setMobileNavState(menu?.hidden ?? true);
  });

  document.querySelectorAll('.mobile-nav__link').forEach(a => {
    a.addEventListener('click', () => {
      setMobileNavState(false);
    });
  });

  const galleryTrack = document.querySelector('[data-gallery-track]') as HTMLDivElement | null;

  if (galleryTrack) {
    let animationFrame = 0;
    let resumeTimer: number | undefined;
    let isDragging = false;
    let pointerId: number | null = null;
    let startX = 0;
    let startScrollLeft = 0;
    let lastTimestamp = 0;

    const getSegmentWidth = () => galleryTrack.scrollWidth / 3;

    const stopAutoScroll = () => {
      if (animationFrame) window.cancelAnimationFrame(animationFrame);
      animationFrame = 0;
      lastTimestamp = 0;
    };

    const normalizeScroll = () => {
      const segmentWidth = getSegmentWidth();
      if (!segmentWidth) return;

      if (galleryTrack.scrollLeft <= segmentWidth * 0.5) {
        galleryTrack.scrollLeft += segmentWidth;
      } else if (galleryTrack.scrollLeft >= segmentWidth * 1.5) {
        galleryTrack.scrollLeft -= segmentWidth;
      }
    };

    const tick = (timestamp: number) => {
      if (!lastTimestamp) lastTimestamp = timestamp;

      const delta = timestamp - lastTimestamp;
      lastTimestamp = timestamp;
      galleryTrack.scrollLeft += (delta * 28) / 1000;
      normalizeScroll();
      animationFrame = window.requestAnimationFrame(tick);
    };

    const startAutoScroll = () => {
      stopAutoScroll();
      if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;
      animationFrame = window.requestAnimationFrame(tick);
    };

    const queueAutoResume = () => {
      if (resumeTimer) window.clearTimeout(resumeTimer);
      resumeTimer = window.setTimeout(() => {
        if (!isDragging) startAutoScroll();
      }, 1400);
    };

    const centerLoop = () => {
      const segmentWidth = getSegmentWidth();
      if (!segmentWidth) return;
      galleryTrack.scrollLeft = segmentWidth;
    };

    galleryTrack.addEventListener('pointerdown', (event) => {
      isDragging = true;
      pointerId = event.pointerId;
      startX = event.clientX;
      startScrollLeft = galleryTrack.scrollLeft;
      galleryTrack.classList.add('is-dragging');
      stopAutoScroll();
      if (resumeTimer) window.clearTimeout(resumeTimer);
      galleryTrack.setPointerCapture(event.pointerId);
    });

    galleryTrack.addEventListener('pointermove', (event) => {
      if (!isDragging || event.pointerId !== pointerId) return;
      const deltaX = event.clientX - startX;
      const segmentWidth = getSegmentWidth();
      let nextScrollLeft = startScrollLeft - deltaX;

      if (segmentWidth) {
        if (nextScrollLeft <= segmentWidth * 0.5) {
          nextScrollLeft += segmentWidth;
          startScrollLeft += segmentWidth;
        } else if (nextScrollLeft >= segmentWidth * 1.5) {
          nextScrollLeft -= segmentWidth;
          startScrollLeft -= segmentWidth;
        }
      }

      galleryTrack.scrollLeft = nextScrollLeft;
    });

    const finishDrag = (event?: PointerEvent) => {
      if (!isDragging) return;
      if (event && event.pointerId !== pointerId) return;

      isDragging = false;
      if (pointerId !== null && galleryTrack.hasPointerCapture(pointerId)) {
        galleryTrack.releasePointerCapture(pointerId);
      }
      pointerId = null;
      galleryTrack.classList.remove('is-dragging');
      normalizeScroll();
      queueAutoResume();
    };

    galleryTrack.addEventListener('pointerup', finishDrag);
    galleryTrack.addEventListener('pointercancel', finishDrag);
    galleryTrack.addEventListener('lostpointercapture', () => {
      finishDrag();
    });
    window.addEventListener('resize', centerLoop);

    centerLoop();
    startAutoScroll();
  }
</script>
