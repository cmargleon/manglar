    .service-card {
      transition: transform 0.25s ease, border-color 0.25s ease, box-shadow 0.25s ease;
    }
    .service-card:hover {
      transform: translateY(-4px);
      border-color: rgba(255,140,149,0.28) !important;
      box-shadow: 0 12px 40px rgba(0,0,0,0.35);
