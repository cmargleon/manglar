---
import { Image } from 'astro:assets';
import Layout from '../layouts/Layout.astro';
import heroVansMujer from '../assets/images/manglar-hero-vans-mujer-marketplace.jpg';
import galleryGorraUnderArmour from '../assets/images/manglar-galeria-gorra-under-armour-hombre.jpeg';
import galleryChamarraLentejuelas from '../assets/images/manglar-galeria-chamarra-lentejuelas-nina.png';
import galleryChamarraDeportiva from '../assets/images/manglar-galeria-chamarra-deportiva-hombre.jpg';
import galleryLookRosa from '../assets/images/manglar-galeria-look-rosa-nina.png';
import productionModaInfantil from '../assets/images/manglar-operacion-catalogo-moda-infantil.png';

const brand = 'Manglar';
const currentYear = new Date().getFullYear();
const whatsappNumber = '525544636484';
const whatsappText = encodeURIComponent(
  'Hola, quiero impulsar mis ventas en Shein y TikTok Shop con Manglar.'
);
const whatsappLink = `https://wa.me/${whatsappNumber}?text=${whatsappText}`;

const whatsappDiagnostico = `https://wa.me/${whatsappNumber}?text=${encodeURIComponent('Hola, quiero solicitar el diagnóstico gratuito de mi tienda en Shein o TikTok Shop.')}`;
const whatsappLive = `https://wa.me/${whatsappNumber}?text=${encodeURIComponent('Hola, me interesa la gestión de TikTok LIVE para mi tienda.')}`;
const whatsappCatalogo = `https://wa.me/${whatsappNumber}?text=${encodeURIComponent('Hola, necesito ayuda con la gestión de catálogo y operación de mi tienda.')}`;

const liveItems = [
  { icon: 'strategy', title: 'Estrategia previa', desc: 'Definimos qué vender, en qué orden y con qué dinámica de precio para maximizar ventas en cada transmisión.' },
  { icon: 'sell', title: 'Productos y promociones', desc: 'Anclamos los productos, creamos las ofertas de LIVE y activamos descuentos en el momento exacto.' },
  { icon: 'live_tv', title: 'Gestión en transmisión', desc: 'Estructura de venta, timing e interacción con audiencia durante el LIVE para mantener el ritmo de compra.' },
  { icon: 'analytics', title: 'Análisis post-LIVE', desc: 'Revisamos métricas, ventas por producto y comportamiento de audiencia para mejorar cada semana.' },
  { icon: 'loop', title: 'Sistema escalable', desc: 'Documentamos lo que funciona y construimos el playbook para escalar el LIVE con una operación comercial estable.' },
];

const heroPhoto = {
  src: heroVansMujer,
  alt: 'Modelo con gorra floral Vans para catálogo de moda femenina operado por Manglar en Shein y TikTok Shop',
  width: 1050,
  widths: [480, 640, 768, 960, 1050],
  sizes: '(max-width: 768px) calc(100vw - 40px), (max-width: 1200px) 46vw, 620px',
  loading: 'eager' as const,
  priority: true,
};

const galleryWidths = [320, 480, 640, 900];
const gallerySizes = '(max-width: 480px) calc(100vw - 40px), (max-width: 768px) calc(50vw - 28px), 320px';

const photos = [
  {
    src: galleryGorraUnderArmour,
    alt: 'Modelo con gorra negra Under Armour para foto de catálogo de ropa deportiva en marketplace',
    width: 900,
    widths: galleryWidths,
    sizes: gallerySizes,
  },
  {
    src: galleryChamarraLentejuelas,
    alt: 'Niña con chamarra rosa de lentejuelas para imagen de producto infantil en catálogo e-commerce',
    width: 900,
    widths: galleryWidths,
    sizes: gallerySizes,
  },
  {
    src: galleryChamarraDeportiva,
    alt: 'Modelo con chamarra deportiva azul marino para visual de catálogo masculino optimizado para marketplace',
    width: 900,
    widths: galleryWidths,
    sizes: gallerySizes,
  },
  {
    src: galleryLookRosa,
    alt: 'Niña con look rosa y falda rayada para foto de producto infantil optimizada para tienda en línea',
    width: 900,
    widths: galleryWidths,
    sizes: gallerySizes,
  },
];

const carouselPhotos = Array.from({ length: 3 }, (_, loopIndex) =>
  photos.map((photo) => ({
    ...photo,
    isDecorative: loopIndex !== 1,
  }))
).flat();

const productionPhoto = {
  src: productionModaInfantil,
  alt: 'Moda infantil para catálogo e-commerce con dos niñas modelando ropa Barbie sobre fondo rosa para marketplace',
  width: 1536,
  widths: [640, 960, 1200, 1536],
  sizes: '100vw',
};

const serviceCards = [
  {
    icon: 'inventory_2',
    title: 'Gestión integral de catálogo',
    items: [
      'Alta y baja de productos por fases',
      'Títulos, atributos y variantes consistentes',
      'Precios y stock al día',
      'Operación estable de 10 a 5,000+ productos',
    ],
  },
  {
    icon: 'photo_camera',
    title: 'Fotos de producto con IA',
    description:
      'Generamos imágenes limpias, consistentes y pensadas para marketplace sin sesiones eternas, sin fotógrafos y sin semanas de espera.',
    label: 'Más conversión visual',
  },
  {
    icon: 'campaign',
    title: 'Campañas, descuentos y eventos',
    description:
      'Configuramos promociones, cupones y campañas internas para aprovechar cada oportunidad de la plataforma y no dejar ventas sobre la mesa.',
  },
  {
    icon: 'live_tv',
    title: 'Gestión completa de TikTok LIVE',
    description:
      'Estrategia, preparación, productos anclados, promociones, dinámica de venta y optimización posterior para convertir LIVE en una operación comercial estable.',
  },
  {
    icon: 'analytics',
    title: 'Optimización continua',
    description:
      'Revisamos desempeño por SKU, identificamos oportunidades rápidas y ajustamos semana a semana para crecer sin caos operativo.',
  },
];

const visualFeatures = [
  {
    title: 'Imágenes listas para marketplace',
    desc: 'Fotos limpias y consistentes para elevar presentación, clic y conversión sin depender de producción tradicional.',
    icon: 'photo_camera',
  },
  {
    title: 'Alternativas cuando tu contenido no alcanza',
    desc: 'Si ya tienes fotos buenas las aprovechamos; si no, generamos nuevas versiones con IA alineadas a tu catálogo.',
    icon: 'compare',
  },
  {
    title: 'Consistencia visual por colección',
    desc: 'Mantenemos una línea estética clara para que el catálogo se vea ordenado y comercial aunque crezca el número de SKUs.',
    icon: 'palette',
  },
];

const partnerLogos = [
  {
    label: 'Barbie',
    sector: 'Moda infantil',
    src: '/logos/barbie.svg',
    alt: 'Logo de Barbie',
    width: 1000,
    height: 495,
  },
  {
    label: 'Vans',
    sector: 'Streetwear',
    src: '/logos/vans.svg',
    alt: 'Logo de Vans',
    width: 444,
    height: 197,
  },
  {
    label: 'Under Armour',
    sector: 'Performance',
    src: '/logos/under-armour.svg',
    alt: 'Logo de Under Armour',
    width: 302,
    height: 177,
  },
  {
    label: 'Messi',
    sector: 'Licencias y retail',
    src: '/logos/messi.svg',
    alt: 'Logo de Messi',
    width: 560,
    height: 180,
  },
];
const partnerLogoLoop = Array.from({ length: 3 }, (_, loopIndex) =>
  partnerLogos.map((logo) => ({
    ...logo,
    isDecorative: loopIndex !== 1,
  }))
).flat();

const steps = [
  {
    n: '01',
    title: 'Diagnóstico',
    desc: 'Revisión de cuenta, catálogo, pricing, fotos y oportunidad rápida.',
  },
  {
    n: '02',
    title: 'Ordenar',
    desc: 'Estandarizamos títulos, atributos, variantes y consistencia visual.',
  },
  {
    n: '03',
    title: 'Operar',
    desc: 'Publicación continua, campañas, descuentos y calendario comercial.',
  },
  {
    n: '04',
    title: 'TikTok LIVE',
    desc: 'Preparamos y operamos el LIVE como herramienta real de ventas.',
  },
  {
    n: '05',
    title: 'Optimizar',
    desc: 'Mejoras semanales para convertir mejor y escalar sin carga extra.',
  },
];

const faqItems = [
  {
    question: '¿En cuánto tiempo suben mi catálogo?',
    bullets: [
      'Depende del volumen, pero trabajamos por fases para que empieces a vender rápido.',
      'Primero estructuramos categorías, variantes, precios y stock.',
      'Luego cargamos por bloques manteniendo calidad y orden.',
      'El objetivo no es solo subir, sino optimizar para vender.',
    ],
    note: 'Si tu catálogo ya viene limpio, avanzamos mucho más rápido.',
  },
  {
    question: '¿Puedo usar mis fotos actuales?',
    bullets: [
      'Sí, siempre que cumplan con los estándares del marketplace.',
      'Si necesitan mejora, optimizamos o generamos alternativas con IA.',
      'Buscamos consistencia visual y mayor conversión.',
    ],
    note: 'Si ya tienes buen contenido, lo aprovechamos. Si no, lo elevamos.',
  },
  {
    question: '¿Ustedes manejan campañas y descuentos?',
    bullets: [
      'Sí. Configuramos campañas, descuentos y eventos según el plan acordado.',
      'Activamos promociones estratégicas y optimizamos fechas clave para maximizar ventas.',
    ],
    note: 'La meta es capturar demanda cuando sube y no dejar dinero en la mesa.',
  },
  {
    question: '¿Qué incluye la gestión de TikTok LIVE?',
    bullets: [
      'Definición de estrategia comercial para el LIVE.',
      'Preparación de productos anclados y promociones.',
      'Estructura de venta durante la transmisión.',
      'Análisis y optimización para siguientes lives.',
      'Construcción de una operación escalable y ordenada.',
    ],
  },
  {
    question: '¿Cómo cobran el servicio?',
    bullets: [
      'Trabajamos con un modelo mensual que depende del número de productos.',
      'También influye la frecuencia de actualizaciones y el volumen operativo.',
      'La cantidad de TikTok Lives gestionados puede modificar el alcance.',
      'En algunos casos puede existir componente variable por venta.',
    ],
    note: 'La cotización exacta sale después de revisar tu catálogo y objetivos.',
  },
];
---

<Layout
  title="Manglar | Agencia para Shein, TikTok Shop y TikTok LIVE en México"
  description="Manglar opera Shein y TikTok Shop de principio a fin en México: catálogo, fotos de producto con IA, campañas, descuentos y TikTok LIVE para vender más sin frenar tu operación."
>
  <style>
    :root {
      --nav-height: 91px;
    }

    #servicios,
    #visuales,
    #ia,
    #marcas,
    #proceso,
    #tiktok-live,
    #faq,
    #contacto {
      scroll-margin-top: 112px;
    }

    main {
      padding-top: var(--nav-height);
    }

    .nav-shell {
      position: fixed;
      top: 0;
      width: 100%;
      z-index: 50;
    }

    .nav-inner {
      max-width: 1400px;
      margin: 0 auto;
      padding: 22px 40px;
      display: flex;
      justify-content: space-between;
      align-items: center;
    }

    .nav-brand {
      font-weight: 900;
      letter-spacing: -0.04em;
      color: #fff;
    }

    .nav-brand-link {
      color: inherit;
      text-decoration: none;
    }

    .nav-links {
      display: flex;
      gap: 40px;
    }

    .nav-link {
      font-weight: 500;
      color: rgba(255,255,255,0.7);
      text-decoration: none;
    }

    .menu-btn {
      background: none;
      border: none;
      cursor: pointer;
      padding: 8px;
      color: #fff;
      align-items: center;
      justify-content: center;
    }

    .menu-icon {
      font-size: 1.5rem;
    }

    .nav-cta {
      background: linear-gradient(135deg, #25D366, #128C7E);
      color: #fff;
      padding: 0.8125rem 1.875rem;
      border-radius: 9999px;
      font-weight: 700;
      letter-spacing: 0.06em;
      text-transform: uppercase;
      text-decoration: none;
      font-family: 'Plus Jakarta Sans', sans-serif;
    }

    .mobile-menu {
      position: fixed;
      top: var(--nav-height);
      left: 0;
      right: 0;
      z-index: 49;
      background: rgba(14,14,14,0.98);
      backdrop-filter: blur(20px);
      border-bottom: 1px solid rgba(255,255,255,0.08);
      padding: 16px 20px 24px;
      flex-direction: column;
      gap: 4px;
    }

    .hero-grid {
      min-height: calc(100vh - var(--nav-height));
      display: grid;
      grid-template-columns: 1fr 1fr;
      overflow: visible;
    }

    .hero-text {
      display: flex;
      flex-direction: column;
      justify-content: center;
      padding: 64px 48px 64px 40px;
      background: #0e0e0e;
      position: relative;
    }

    .hero-kicker {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      background: linear-gradient(135deg, #ff8c95, #e80048);
      padding: 0.4375rem 1rem;
      border-radius: 9999px;
      margin-bottom: 28px;
      width: fit-content;
    }

    .hero-kicker-dot {
      width: 6px;
      height: 6px;
      background: #fff;
      border-radius: 50%;
      display: inline-block;
    }

    .hero-kicker-copy {
      font-weight: 700;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: #fff;
    }

    .hero-title {
      font-weight: 900;
      line-height: 0.92;
      letter-spacing: -0.04em;
      margin-bottom: 24px;
      max-width: 760px;
    }

    .hero-copy {
      line-height: 1.7;
      color: rgba(255,255,255,0.7);
      max-width: 530px;
      margin-bottom: 32px;
    }

    .hero-actions {
      display: flex;
      gap: 16px;
      align-items: center;
      flex-wrap: wrap;
    }

    .hero-primary-cta {
      background: linear-gradient(135deg, #25D366, #128C7E);
      padding: 1rem 2rem;
      border-radius: 9999px;
      color: #fff;
      text-decoration: none;
      font-family: 'Plus Jakarta Sans', sans-serif;
      font-weight: 700;
    }

    .hero-secondary-link {
      color: rgba(255,255,255,0.6);
      font-weight: 600;
      text-decoration: none;
    }

    .ia-title {
      line-height: 0.94;
      margin-bottom: 24px;
    }

    .hero-photo {
      position: relative;
      overflow: hidden;
      background: #d6d0c8;
    }

    .hero-photo-overlay {
      position: absolute;
      inset: 0;
      background: linear-gradient(to right, #0e0e0e 0%, transparent 20%);
      pointer-events: none;
    }

    .services-section {
      padding: 104px 40px 120px;
    }

    .services-intro {
      margin-bottom: 64px;
      max-width: 760px;
    }

    .section-divider {
      height: 3px;
      width: 72px;
      background: linear-gradient(90deg, #ff8c95, #e80048);
      border-radius: 9999px;
      margin-top: 20px;
    }

    .services-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 16px;
    }

    .service-card {
      background: #161616;
      border-radius: 1.5rem;
      padding: 36px;
      border: 1px solid rgba(255,255,255,0.06);
    }

    .service-card--catalog {
      grid-column: span 2;
      padding: 48px;
      position: relative;
      overflow: hidden;
    }

    .service-card--live {
      border-color: rgba(255,140,149,0.18);
      display: flex;
      flex-direction: column;
      justify-content: space-between;
    }

    .service-icon-lg {
      font-size: 3rem;
      color: #ff8c95;
      margin-bottom: 24px;
      display: block;
    }

    .service-icon-md {
      font-size: 2.5rem;
      margin-bottom: 20px;
      display: block;
      color: #ff8c95;
    }

    .service-icon-circle {
      width: 48px;
      height: 48px;
      border-radius: 50%;
      background: linear-gradient(135deg, #ff8c95, #e80048);
      display: flex;
      align-items: center;
      justify-content: center;
      margin-bottom: 24px;
    }

    .service-icon-circle-symbol {
      font-size: 1.5rem;
      color: #fff;
    }

    .service-title {
      font-weight: 900;
      margin-bottom: 12px;
    }

    .service-title--xl {
      margin-bottom: 16px;
    }

    .service-copy {
      line-height: 1.65;
      color: rgba(255,255,255,0.58);
    }

    .service-copy--live {
      line-height: 1.7;
      color: rgba(255,255,255,0.62);
    }

    .service-list {
      list-style: none;
      padding: 0;
      display: flex;
      flex-direction: column;
      gap: 10px;
    }

    .service-list-item {
      display: flex;
      align-items: center;
      gap: 10px;
      color: rgba(255,255,255,0.66);
    }

    .service-check {
      font-size: 1rem;
      color: #ff8c95;
    }

    .service-bg-icon-wrap {
      position: absolute;
      bottom: -20px;
      right: -20px;
      opacity: 0.04;
    }

    .service-bg-icon {
      font-size: 12.5rem;
      color: #ff8c95;
    }

    .fullwidth-section {
      position: relative;
      min-height: 680px;
      overflow: hidden;
      display: flex;
      align-items: flex-end;
    }

    .fullwidth-image {
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%;
      object-fit: cover;
      object-position: center 30%;
      filter: brightness(0.6);
    }

    .fullwidth-overlay {
      position: absolute;
      inset: 0;
      background: linear-gradient(to top, #0e0e0e 0%, rgba(14,14,14,0.2) 60%, transparent 100%);
    }

    .fullwidth-text {
      position: relative;
      z-index: 1;
      width: 100%;
      padding: 60px 40px;
      max-width: 1400px;
      margin: 0 auto;
      box-sizing: border-box;
    }

    .problem-title {
      font-weight: 900;
      letter-spacing: -0.04em;
      margin-bottom: 12px;
    }

    .problem-copy {
      color: rgba(255,255,255,0.72);
      max-width: 640px;
      line-height: 1.65;
      margin-bottom: 28px;
    }

    .problem-pills {
      display: grid;
      grid-template-columns: repeat(4, minmax(0, 1fr));
      gap: 12px;
      max-width: 980px;
    }

    .problem-pill {
      padding: 16px 18px;
      border-radius: 1rem;
      background: rgba(14,14,14,0.72);
      backdrop-filter: blur(10px);
      border: 1px solid rgba(255,255,255,0.08);
    }

    .problem-pill-head {
      display: flex;
      align-items: center;
      gap: 8px;
      margin-bottom: 6px;
    }

    .problem-pill-icon {
      font-size: 1.1rem;
      color: #ff8c95;
    }

    .problem-pill-title {
      font-weight: 700;
      color: rgba(255,255,255,0.9);
    }

    .problem-pill-copy {
      line-height: 1.55;
      color: rgba(255,255,255,0.55);
      margin: 0;
    }

    .container-wide {
      max-width: 1400px;
      margin: 0 auto;
    }

    .accent-em {
      color: #ff8c95;
      font-style: italic;
    }

    .accent-italic {
      font-style: italic;
    }

    .accent-em--gallery {
      display: inline-block;
      margin-top: 0.08em;
    }

    .gallery-section {
      padding: 120px 40px;
      background: #0a0a0a;
    }

    .gallery-header {
      display: flex;
      justify-content: space-between;
      align-items: flex-end;
      margin-bottom: 64px;
      gap: 32px;
    }

    .gallery-quote {
      margin-top: 16px;
      max-width: 520px;
      font-style: italic;
      color: rgba(255,255,255,0.58);
      line-height: 1.65;
    }

    .ia-section {
      padding: 120px 40px;
    }

    .ia-copy-text {
      margin: 0;
      max-width: 52ch;
      line-height: 1.75;
      color: rgba(255,255,255,0.66);
    }

    .ia-icon-badge,
    .live-feature-icon-wrap {
      width: 44px;
      height: 44px;
      background: linear-gradient(135deg, rgba(255,140,149,0.15), rgba(232,0,72,0.1));
      border-radius: 12px;
      display: flex;
      align-items: center;
      justify-content: center;
      border: 1px solid rgba(255,140,149,0.2);
      flex-shrink: 0;
    }

    .ia-icon,
    .live-feature-icon {
      font-size: 1.3rem;
      color: #ff8c95;
    }

    .ia-feature-title {
      margin: 0 0 6px;
      font-weight: 700;
    }

    .ia-feature-copy {
      margin: 0;
      line-height: 1.65;
      color: rgba(255,255,255,0.6);
    }

    .brands-section {
      padding: 80px 40px 100px;
      background: #0e0e0e;
    }

    .brands-title {
      font-weight: 900;
      letter-spacing: -0.04em;
      line-height: 0.96;
      margin-bottom: 56px;
      text-align: center;
    }

    .brand-logo-item {
      flex-shrink: 0;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 0 40px;
    }

    .brand-logo-image {
      height: 4.5rem;
      width: auto;
      object-fit: contain;
    }

    .steps-section {
      padding: 0 40px 120px;
      background:
        linear-gradient(180deg, #0e0e0e 0%, #090909 100%);
    }

    .steps-inner {
      max-width: 1400px;
      margin: 0 auto;
      padding-top: 96px;
      border-top: 1px solid rgba(255,255,255,0.05);
    }

    .steps-header {
      display: grid;
      grid-template-columns: minmax(0, 1.1fr) minmax(0, 0.9fr);
      gap: 32px;
      align-items: end;
      margin-bottom: 56px;
    }

    .steps-kicker {
      display: inline-flex;
      align-items: center;
      gap: 10px;
      margin-bottom: 18px;
      color: #ff8c95;
      font-weight: 800;
      letter-spacing: 0.12em;
      text-transform: uppercase;
    }

    .steps-kicker::before {
      content: "";
      width: 8px;
      height: 8px;
      border-radius: 999px;
      background: linear-gradient(135deg, #ff8c95, #e80048);
      box-shadow: 0 0 18px rgba(255,140,149,0.42);
    }

    .steps-intro {
      margin: 0;
      max-width: 560px;
      color: rgba(255,255,255,0.64);
      line-height: 1.75;
    }

    .steps-grid {
      position: relative;
      display: grid;
      grid-template-columns: repeat(5, minmax(0, 1fr));
      gap: 18px;
      align-items: stretch;
    }

    .steps-line {
      position: absolute;
      top: 42px;
      left: 42px;
      right: 42px;
      height: 1px;
      background: linear-gradient(90deg, rgba(255,140,149,0.28), rgba(255,255,255,0.08));
