---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  canonicalUrl?: string;
  faqItems?: {
    question: string;
    answer: string;
  }[];
}

const siteName = 'Manglar';
const siteUrl = 'https://agenciamanglar.mx';
const defaultCanonicalUrl = `${siteUrl}/`;
const {
  title = "Manglar | Agencia para Shein y TikTok Shop en México",
  description = "Manglar opera Shein y TikTok Shop en México: catálogo, fotos de producto con IA, campañas, descuentos y TikTok LIVE para vender más con una operación ordenada.",
  canonicalUrl = defaultCanonicalUrl,
  faqItems = [],
} = Astro.props;

const canonicalHref = new URL(canonicalUrl, defaultCanonicalUrl).href;
const ogImage = `${siteUrl}/og-image.jpg`;
const ogImageAlt =
  'Manglar, agencia para operar catálogo, fotos con IA y TikTok LIVE en Shein y TikTok Shop en México';
const telephone = '+52 55 4463 6484';
const googleSiteVerification = import.meta.env.PUBLIC_GOOGLE_SITE_VERIFICATION;

const organizationSchema = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  '@id': `${siteUrl}/#organization`,
  name: siteName,
  url: siteUrl,
  logo: `${siteUrl}/favicon.svg`,
  image: ogImage,
  email: 'contacto@agenciamanglar.mx',
  telephone,
  description:
    'Agencia especializada en operación integral de tiendas Shein y TikTok Shop: catálogo, fotos con IA, campañas, descuentos y TikTok LIVE.',
  sameAs: [
    'https://tiktok.com/@agenciamanglar.mx',
    'https://instagram.com/agenciamanglar.mx',
  ],
  areaServed: {
    '@type': 'Country',
    name: 'Mexico',
  },
  brand: {
    '@type': 'Brand',
    name: siteName,
  },
  contactPoint: {
    '@type': 'ContactPoint',
    contactType: 'sales',
    email: 'contacto@agenciamanglar.mx',
    telephone,
    availableLanguage: ['es-MX'],
    areaServed: 'MX',
  },
  knowsAbout: [
    'Agencia Shein México',
    'Gestión TikTok Shop',
    'TikTok LIVE ventas',
    'Operación e-commerce',
    'Catálogo marketplace',
    'Fotos de producto con IA',
  ],
};

const serviceSchema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  '@id': `${siteUrl}/#service`,
  serviceType: 'Gestión integral de marketplaces',
  name: 'Operación integral de tiendas Shein y TikTok Shop',
  provider: {
    '@id': `${siteUrl}/#organization`,
  },
  areaServed: {
    '@type': 'Country',
    name: 'Mexico',
  },
  availableLanguage: ['es-MX'],
  url: canonicalHref,
  description:
    'Gestión completa de catálogo, fotos de producto con IA, campañas, descuentos y TikTok LIVE para marcas y tiendas que venden en Shein y TikTok Shop.',
};

const websiteSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  '@id': `${siteUrl}/#website`,
  url: siteUrl,
  name: siteName,
  inLanguage: 'es-MX',
  publisher: {
    '@id': `${siteUrl}/#organization`,
  },
};

const webPageSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  '@id': `${canonicalHref}#webpage`,
  url: canonicalHref,
  name: title,
  description,
  inLanguage: 'es-MX',
  isPartOf: {
    '@type': 'WebSite',
    '@id': `${siteUrl}/#website`,
    name: siteName,
    url: siteUrl,
  },
  about: {
    '@id': `${siteUrl}/#service`,
  },
  primaryImageOfPage: {
    '@type': 'ImageObject',
    url: ogImage,
    width: 1200,
    height: 630,
  },
};

const faqSchema =
  faqItems.length > 0
    ? {
        '@context': 'https://schema.org',
        '@type': 'FAQPage',
        '@id': `${canonicalHref}#faq`,
        mainEntity: faqItems.map((item) => ({
          '@type': 'Question',
          name: item.question,
          acceptedAnswer: {
            '@type': 'Answer',
            text: item.answer,
          },
        })),
      }
    : undefined;

const structuredData = [
  organizationSchema,
  serviceSchema,
  websiteSchema,
  webPageSchema,
  faqSchema,
].filter(Boolean);
---

<!doctype html>
<html lang="es-MX">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="author" content={siteName} />
    <meta name="theme-color" content="#0e0e0e" />
    <meta name="robots" content="index, follow" />
    <meta name="googlebot" content="index, follow, max-snippet:-1, max-image-preview:large, max-video-preview:-1" />
    <link rel="canonical" href={canonicalHref} />
    <link rel="alternate" hreflang="es-MX" href={canonicalHref} />
    <link rel="alternate" hreflang="x-default" href={canonicalHref} />
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    {googleSiteVerification && (
      <meta name="google-site-verification" content={googleSiteVerification} />
    )}

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalHref} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:secure_url" content={ogImage} />
    <meta property="og:image:type" content="image/jpeg" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={ogImageAlt} />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:locale" content="es_MX" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <meta name="twitter:image:alt" content={ogImageAlt} />

    <title>{title}</title>

    {structuredData.map((schema) => (
      <script type="application/ld+json" set:html={JSON.stringify(schema)} />
    ))}

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@600;700;800;900&family=Manrope:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <link
      href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200"
      rel="stylesheet"
    />
  </head>
  <body>
    <slot />
  </body>
</html>
